<!--
  Keep in sync with CORE_KernelLogic/asconfig.json. Paths relative to this file.
  library-path / external-library-path are passed by build.bat with += so
  air-config defaults (airglobal, framework) are preserved.
-->
<flex-config>
	<compiler>
		<debug>true</debug>
		<source-path>
			<path-element>../../../CORE_KernelLogic/src</path-element>
			<path-element>../../../CORE_KernelLogic/global</path-element>
			<path-element>../../../LIB_Other/lib/Flash/src</path-element>
		</source-path>
	</compiler>
	<include-sources>
		<path-element>../../../CORE_KernelLogic/src</path-element>
		<path-element>../../../CORE_KernelLogic/global</path-element>
	</include-sources>
	<output>../../../out/production/CORE_KernelLogic/CORE_KernelLogic.swc</output>
</flex-config>
