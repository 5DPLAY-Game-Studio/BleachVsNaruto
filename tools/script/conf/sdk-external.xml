<!--
  Shared fragment for library modules (bat / IDEA additionalOptions).
  Append Flex/AIR/MX onto external-library-path so library SWCs do not merge
  mx.* (same intent as asconfig.json). MUST use append="true": without it,
  load-config+= replaces the whole list and drops IDEA/bat paths such as
  shared/lib/swc. Also never clear library-path (IDEA Merged module SWCs).
  ${flexlib} = SDK frameworks directory.
-->
<flex-config>
	<compiler>
		<external-library-path append="true">
			<path-element>${flexlib}/libs</path-element>
			<path-element>${flexlib}/libs/air</path-element>
			<path-element>${flexlib}/libs/mx</path-element>
		</external-library-path>
	</compiler>
</flex-config>
