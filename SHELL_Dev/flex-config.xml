<!--
  与 asconfig.json 保持同步。路径相对于此模块根目录。
  通过 tools/script/conf/sdk-external.xml (build.bat / IDEA) 实现 Flex/AIR/MX。
-->
<flex-config>
	<!-- 编译器选项 -->
	<compiler>
		<!-- 构建调试版本 -->
		<debug>true</debug>
		
		<!-- 是否优化 -->
		<optimize>false</optimize>
		
		<!-- 是否开启遥感数据 -->
		<advanced-telemetry>true</advanced-telemetry>
		
		<!-- 源代码路径，通常内容是和 include-sources 相同 -->
		<source-path>
			<path-element>src</path-element>
			<path-element>../CORE_KernelLogic/global</path-element>
			
			<path-element>../shared/_tmp/dev</path-element>
		</source-path>
		
		<!-- 库文件的三种链接方式：Merged、External 和 Include -->
		<!-- Merged -->
		<library-path append="true">
			<path-element>../out/production/CORE_KernelLogic/CORE_KernelLogic.swc</path-element>
			<path-element>../out/production/LIB_KyoLib/LIB_KyoLib.swc</path-element>
			<path-element>../out/production/CORE_Utils/CORE_Utils.swc</path-element>
			<path-element>../out/production/CORE_Shared/CORE_Shared.swc</path-element>
			
			<path-element>lib/swc</path-element>
		</library-path>
		
		<!-- External -->
		<external-library-path append="true">
			<path-element>../shared/lib/swc</path-element>
		</external-library-path>
		
		<!-- Include -->
		<include-libraries append="true">
		</include-libraries>
	</compiler>
	
	<!-- SWF 版本 -->
	<swf-version>37</swf-version>
	
	<!-- 是否使用网络 -->
	<use-network>false</use-network>
	
	<!-- 是否使用 direct-blit -->
	<use-direct-blit>true</use-direct-blit>
	
	<!-- 是否使用 GPU -->
	<use-gpu>true</use-gpu>
	
	<!-- 包含符号类 -->
	<includes>
		<symbol>_ALL_GLOBALS_</symbol>
	</includes>
	
	<!-- 输出路径（默认使用 IDEA 的生成路径） -->
	<output>../out/production/SHELL_Dev/FighterTester.swf</output>
</flex-config>
